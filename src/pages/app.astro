---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Dashboard | Vdiga"
  description="Vdiga dashboard за AI телефонен асистент, разговори, lead-ове, календар и настройки."
  path="/app"
>
  <section class="section app-section">
    <div class="container app-wrap">
      <div class="app-heading">
        <p class="eyebrow">Vdiga dashboard</p>
        <h1>Контролен панел</h1>
        <p class="lead" data-app-status>Проверяваме сесията...</p>
      </div>

      <form class="onboarding-panel" hidden data-onboarding-form>
        <div>
          <p class="eyebrow">Първа настройка</p>
          <h2>Данни за бизнеса</h2>
          <p>Тези данни ще създадат tenant профила, към който после ще вържем subscription, DIDWW и Retell.</p>
        </div>

        <label>
          Име на бизнес
          <input required name="business_name" autocomplete="organization" placeholder="Дентална клиника Иванови" />
        </label>

        <label>
          Ниша
          <select name="niche">
            <option value="">Изберете ниша</option>
            <option value="dental">Зъболекар / дентална клиника</option>
            <option value="clinic">Клиника / медицински услуги</option>
            <option value="beauty">Салон / beauty</option>
            <option value="auto_service">Автосервиз</option>
            <option value="real_estate">Имоти</option>
            <option value="hotel">Хотел / туризъм</option>
            <option value="general_services">Услуги</option>
          </select>
        </label>

        <label>
          Град
          <input name="city" autocomplete="address-level2" placeholder="София" />
        </label>

        <label>
          Бизнес телефон
          <input name="main_phone" autocomplete="tel" placeholder="+359..." />
        </label>

        <label>
          Контактен email
          <input name="contact_email" type="email" autocomplete="email" placeholder="office@example.com" />
        </label>

        <label class="checkbox-label">
          <input name="wants_booking" type="checkbox" />
          Искам записване на часове през календар
        </label>

        <button class="btn btn-primary" type="submit">Създай бизнес профил</button>
        <p class="app-message" data-onboarding-message></p>
      </form>

      <div class="app-grid" hidden data-app-content>
        <article class="plan-panel" data-plan-panel>
          <div>
            <span class="panel-label">Абонамент</span>
            <h2>Изберете план</h2>
            <p data-plan-status>Планът още не е избран.</p>
          </div>

          <div class="plan-list">
            <button class="plan-option" type="button" data-plan-key="start">
              <strong>Старт</strong>
              <span>AI отговор 24/7 и call summaries</span>
            </button>
            <button class="plan-option" type="button" data-plan-key="booking">
              <strong>24/7 + часове</strong>
              <span>AI разговори + записване в календар</span>
            </button>
            <button class="plan-option" type="button" data-plan-key="multilingual">
              <strong>Многоезичен</strong>
              <span>Български + английски и premium setup</span>
            </button>
          </div>
        </article>

        <article class="app-panel">
          <span class="panel-label">Статус</span>
          <h2>AI асистент</h2>
          <p data-provisioning-status>Provisioning още не е стартиран.</p>
        </article>

        <article class="app-panel">
          <span class="panel-label">Телефония</span>
          <h2>Forwarding номер</h2>
          <p data-phone-status>Зареждаме телефонната настройка...</p>
        </article>

        <article class="app-panel call-history-panel">
          <span class="panel-label">Разговори</span>
          <h2>Call history</h2>
          <p data-call-status>Зареждаме последните разговори...</p>
          <div class="call-list" data-call-list></div>
        </article>

        <article class="app-panel lead-panel">
          <span class="panel-label">Lead-ове</span>
          <h2>Нови заявки</h2>
          <p data-lead-status>Зареждаме заявките от разговорите...</p>
          <div class="lead-list" data-lead-list></div>
        </article>

        <article class="app-panel calendar-panel">
          <span class="panel-label">Calendar</span>
          <h2>Записвания</h2>
          <p data-calendar-status>Зареждаме calendar setup...</p>

          <div class="calendar-provider-grid" data-calendar-providers>
            <button type="button" data-calendar-provider="google_calendar">
              <strong>Google Calendar</strong>
              <span>Свържете един или повече Google календари за хора, стаи или ресурси.</span>
            </button>
          </div>

          <div class="calendar-connection" hidden data-calendar-connection></div>

          <p class="app-message" data-calendar-message></p>
        </article>

        <article class="app-panel business-profile-panel" data-business-profile-panel>
          <div class="panel-title-row">
            <div>
              <span class="panel-label">Настройки</span>
              <h2>Бизнес профил</h2>
            </div>
            <button class="btn btn-secondary btn-small" type="button" data-business-edit-toggle>Редактирай</button>
          </div>

          <div class="business-summary" data-business-summary>
            <p>Зареждаме въведените данни...</p>
          </div>

          <form class="business-edit-form" hidden data-business-edit-form>
            <label>
              Име на бизнес
              <input required name="business_name" autocomplete="organization" />
            </label>

            <label>
              Ниша
              <select name="niche">
                <option value="">Изберете ниша</option>
                <option value="dental">Зъболекар / дентална клиника</option>
                <option value="clinic">Клиника / медицински услуги</option>
                <option value="beauty">Салон / beauty</option>
                <option value="auto_service">Автосервиз</option>
                <option value="real_estate">Имоти</option>
                <option value="hotel">Хотел / туризъм</option>
                <option value="general_services">Услуги</option>
              </select>
            </label>

            <label>
              Град
              <input name="city" autocomplete="address-level2" />
            </label>

            <label>
              Бизнес телефон
              <input name="main_phone" autocomplete="tel" />
            </label>

            <label>
              Контактен email
              <input name="contact_email" type="email" autocomplete="email" />
            </label>

            <div class="form-actions">
              <button class="btn btn-primary btn-small" type="submit">Запази</button>
              <button class="btn btn-secondary btn-small" type="button" data-business-edit-cancel>Откажи</button>
            </div>
          </form>

          <p class="app-message" data-business-message></p>
        </article>
      </div>

      <button class="btn btn-secondary" type="button" hidden data-logout>Изход</button>
    </div>
  </section>
</BaseLayout>

<script>
  import { supabase, isSupabaseConfigured } from "../lib/supabase";

  const status = document.querySelector<HTMLElement>("[data-app-status]");
  const content = document.querySelector<HTMLElement>("[data-app-content]");
  const logout = document.querySelector<HTMLButtonElement>("[data-logout]");
  const onboardingForm = document.querySelector<HTMLFormElement>("[data-onboarding-form]");
  const onboardingMessage = document.querySelector<HTMLElement>("[data-onboarding-message]");
  const planStatus = document.querySelector<HTMLElement>("[data-plan-status]");
  const planButtons = document.querySelectorAll<HTMLButtonElement>("[data-plan-key]");
  const provisioningStatus = document.querySelector<HTMLElement>("[data-provisioning-status]");
  const phoneStatus = document.querySelector<HTMLElement>("[data-phone-status]");
  const callStatus = document.querySelector<HTMLElement>("[data-call-status]");
  const callList = document.querySelector<HTMLElement>("[data-call-list]");
  const leadStatus = document.querySelector<HTMLElement>("[data-lead-status]");
  const leadList = document.querySelector<HTMLElement>("[data-lead-list]");
  const calendarStatus = document.querySelector<HTMLElement>("[data-calendar-status]");
  const calendarProviders = document.querySelector<HTMLElement>("[data-calendar-providers]");
  const calendarProviderButtons = document.querySelectorAll<HTMLButtonElement>("[data-calendar-provider]");
  const calendarConnection = document.querySelector<HTMLElement>("[data-calendar-connection]");
  const calendarMessage = document.querySelector<HTMLElement>("[data-calendar-message]");
  const businessSummary = document.querySelector<HTMLElement>("[data-business-summary]");
  const businessEditToggle = document.querySelector<HTMLButtonElement>("[data-business-edit-toggle]");
  const businessEditCancel = document.querySelector<HTMLButtonElement>("[data-business-edit-cancel]");
  const businessEditForm = document.querySelector<HTMLFormElement>("[data-business-edit-form]");
  const businessMessage = document.querySelector<HTMLElement>("[data-business-message]");
  let activeTenantId: string | null = null;
  let activeBusinessProfile: any = null;

  const setStatus = (value: string) => {
    if (status) status.textContent = value;
  };

  const formatDateTime = (value?: string | null) => {
    if (!value) return "няма дата";
    return new Intl.DateTimeFormat("bg-BG", {
      dateStyle: "short",
      timeStyle: "short",
    }).format(new Date(value));
  };

  const renderEmptyState = (element: HTMLElement | null, message: string) => {
    if (!element) return;
    element.innerHTML = `<p class="empty-state">${message}</p>`;
  };

  const escapeHtml = (value: string) => {
    const div = document.createElement("div");
    div.textContent = value;
    return div.innerHTML;
  };

  const setCalendarMessage = (value: string) => {
    if (calendarMessage) calendarMessage.textContent = value;
  };

  const nicheLabels: Record<string, string> = {
    dental: "Зъболекар / дентална клиника",
    clinic: "Клиника / медицински услуги",
    beauty: "Салон / beauty",
    auto_service: "Автосервиз",
    real_estate: "Имоти",
    hotel: "Хотел / туризъм",
    general_services: "Услуги",
  };

  const cleanValue = (value?: string | null) => value?.trim() || "";

  const getStatusLabel = (value?: string | null) => {
    const labels: Record<string, string> = {
      active: "Активен",
      connected: "Свързан",
      succeeded: "Готов",
      running: "Настройва се",
      queued: "На опашка",
      waiting_for_customer: "Нужна настройка",
      failed: "Проблем",
      pending_payment: "Очаква плащане",
      incomplete: "Незавършен",
    };

    if (!value) return "Не е настроено";
    return labels[value] || value;
  };

  const renderBusinessProfile = (profile: any) => {
    activeBusinessProfile = profile;

    if (!businessSummary || !businessEditForm) return;

    if (!profile) {
      businessSummary.innerHTML = '<p class="empty-state">Няма намерени бизнес данни към този профил.</p>';
      businessEditForm.setAttribute("hidden", "");
      return;
    }

    const details = [
      ["Бизнес", cleanValue(profile.business_name)],
      ["Ниша", nicheLabels[cleanValue(profile.niche)] || cleanValue(profile.niche)],
      ["Град", cleanValue(profile.city)],
      ["Телефон", cleanValue(profile.main_phone)],
      ["Email", cleanValue(profile.contact_email)],
    ];

    businessSummary.innerHTML = details
      .map(([label, value]) => `
        <div class="business-summary-item ${value ? "" : "is-missing"}">
          <span>${escapeHtml(label)}</span>
          <strong>${escapeHtml(value || "Липсва")}</strong>
        </div>
      `)
      .join("");

    const form = businessEditForm;
    (form.elements.namedItem("business_name") as HTMLInputElement).value = cleanValue(profile.business_name);
    (form.elements.namedItem("niche") as HTMLSelectElement).value = cleanValue(profile.niche);
    (form.elements.namedItem("city") as HTMLInputElement).value = cleanValue(profile.city);
    (form.elements.namedItem("main_phone") as HTMLInputElement).value = cleanValue(profile.main_phone);
    (form.elements.namedItem("contact_email") as HTMLInputElement).value = cleanValue(profile.contact_email);
  };

  const setBusinessEditing = (isEditing: boolean) => {
    if (!businessEditForm || !businessEditToggle || !businessSummary) return;

    businessEditForm.toggleAttribute("hidden", !isEditing);
    businessSummary.toggleAttribute("hidden", isEditing);
    businessEditToggle.textContent = isEditing ? "Затвори" : "Редактирай";

    if (isEditing && activeBusinessProfile) {
      renderBusinessProfile(activeBusinessProfile);
    }
  };

  const loadBusinessProfile = async (tenantId: string) => {
    if (!supabase) return;

    const { data: profiles, error } = await supabase
      .from("business_profiles")
      .select("business_name, niche, city, main_phone, contact_email")
      .eq("tenant_id", tenantId)
      .limit(1);

    if (error) {
      if (businessSummary) businessSummary.innerHTML = `<p class="empty-state">Не успяхме да заредим бизнес профила: ${escapeHtml(error.message)}</p>`;
      return;
    }

    renderBusinessProfile(profiles?.[0] || null);
  };

  const startGoogleCalendarAuth = async (mode = "solo_google") => {
    if (!supabase || !activeTenantId) return;

    setCalendarMessage("Подготвяме Google OAuth...");
    const { data, error } = await supabase.functions.invoke("google-calendar-auth-start", {
      body: {
        tenant_id: activeTenantId,
        mode,
      },
    });

    if (error) {
      setCalendarMessage("Google OAuth endpoint още не е конфигуриран. UI и базата са готови за връзката.");
      return;
    }

    const authUrl = typeof data === "object" && data && "auth_url" in data ? String(data.auth_url) : "";
    if (!authUrl) {
      setCalendarMessage("Google OAuth endpoint не върна auth URL.");
      return;
    }

    window.location.assign(authUrl);
  };

  const loadPhoneNumbers = async (tenantId: string) => {
    if (!supabase || !phoneStatus) return;

    const { data: numbers, error } = await supabase
      .from("phone_numbers")
      .select("didww_number, retell_phone_number, original_business_number, status, last_test_call_at")
      .eq("tenant_id", tenantId)
      .order("updated_at", { ascending: false })
      .limit(1);

    if (error) {
      phoneStatus.textContent = `Не успяхме да заредим номера: ${error.message}`;
      return;
    }

    const number = numbers?.[0];
    if (!number) {
      phoneStatus.textContent = "Няма записан forwarding номер още.";
      return;
    }

    phoneStatus.textContent = `Номер: ${number.didww_number || number.retell_phone_number || "няма"} · ${getStatusLabel(number.status)}`;
  };

  const loadCalls = async (tenantId: string) => {
    if (!supabase || !callStatus || !callList) return;

    const { data: calls, error } = await supabase
      .from("calls")
      .select("retell_call_id, from_number, to_number, status, duration_seconds, summary, transcript, created_at")
      .eq("tenant_id", tenantId)
      .order("created_at", { ascending: false })
      .limit(5);

    if (error) {
      callStatus.textContent = `Не успяхме да заредим разговорите: ${error.message}`;
      return;
    }

    if (!calls?.length) {
      callStatus.textContent = "Още няма записани Retell разговори.";
      renderEmptyState(callList, "След webhook теста тук ще се появи последният call.");
      return;
    }

    callStatus.textContent = `Последни ${calls.length} разговора`;
    callList.innerHTML = calls.map((call) => {
      const excerpt = call.summary || call.transcript || "Няма summary/transcript още.";
      return `
        <article class="call-item">
          <div class="call-item-top">
            <strong>${escapeHtml(call.from_number || "непознат номер")}</strong>
            <span>${escapeHtml(call.status)}</span>
          </div>
          <p>${escapeHtml(excerpt.slice(0, 220))}</p>
          <small>${formatDateTime(call.created_at)} · ${call.duration_seconds || 0}s · ${escapeHtml(call.retell_call_id || "")}</small>
        </article>
      `;
    }).join("");
  };

  const loadLeads = async (tenantId: string) => {
    if (!supabase || !leadStatus || !leadList) return;

    const { data: leads, error } = await supabase
      .from("leads")
      .select("name, phone, intent, notes, status, created_at")
      .eq("tenant_id", tenantId)
      .order("created_at", { ascending: false })
      .limit(5);

    if (error) {
      leadStatus.textContent = `Не успяхме да заредим lead-овете: ${error.message}`;
      return;
    }

    if (!leads?.length) {
      leadStatus.textContent = "Още няма извлечени заявки.";
      renderEmptyState(leadList, "След analyzed call тук ще има име, телефон и услуга.");
      return;
    }

    leadStatus.textContent = `Последни ${leads.length} заявки`;
    leadList.innerHTML = leads.map((lead) => `
      <article class="lead-item">
        <div class="call-item-top">
          <strong>${escapeHtml(lead.name || "Без име")}</strong>
          <span>${escapeHtml(lead.status)}</span>
        </div>
        <p>${escapeHtml(lead.intent || lead.notes || "Няма описана услуга още.")}</p>
        <small>${escapeHtml(lead.phone || "няма телефон")} · ${formatDateTime(lead.created_at)}</small>
      </article>
    `).join("");
  };

  const renderCalendarConnection = (connections: any[], resources: any[]) => {
    if (!calendarConnection || !calendarStatus) return;

    if (!connections.length) {
      calendarStatus.textContent = "Календарът още не е свързан.";
      calendarProviders?.removeAttribute("hidden");
      calendarConnection.setAttribute("hidden", "");
      return;
    }

    calendarProviders?.setAttribute("hidden", "");
    calendarConnection.removeAttribute("hidden");

    const connectedCount = connections.length;

    calendarStatus.textContent = `${connectedCount} Google ${connectedCount === 1 ? "календар" : "календара"} · ${resources.length} ${resources.length === 1 ? "ресурс" : "ресурса"}`;
    calendarConnection.innerHTML = `
      <div class="calendar-state">
        <div>
          <strong>Google Calendar</strong>
          <span>Свързан</span>
        </div>
        <p>Всеки календар може да носи име на човек, кабинет или ресурс, за да се избира правилният слот при записване.</p>
      </div>
      <div class="calendar-actions">
        <button type="button" data-add-google-calendar>Добави Google календар</button>
      </div>
      <div class="calendar-account-list">
        ${connections.map((connection) => `
          <div class="calendar-account">
            <strong>${escapeHtml(connection.connected_email || "Google account")}</strong>
            <small>${escapeHtml(connection.selected_calendar_name || connection.selected_calendar_id || "няма избран календар")}</small>
          </div>
        `).join("")}
      </div>
      <div class="calendar-resource-list">
        <strong>Хора и ресурси</strong>
        ${
          resources.length
            ? resources.map((resource) => `
                <form class="calendar-resource" data-resource-form data-resource-id="${escapeHtml(resource.id)}">
                  <label>
                    Име
                    <input name="name" value="${escapeHtml(resource.name || "")}" placeholder="Напр. д-р Иванова" />
                  </label>
                  <small>${escapeHtml(resource.provider_calendar_name || resource.provider_calendar_id || "Google calendar")} · ${escapeHtml(resource.provider_account_email || "")}</small>
                  <button type="submit">Запази</button>
                </form>
              `).join("")
            : '<p class="empty-state">Още няма добавени лекари/календари.</p>'
        }
      </div>
    `;

    calendarConnection
      .querySelector<HTMLButtonElement>("[data-add-google-calendar]")
      ?.addEventListener("click", () => startGoogleCalendarAuth("multi_google"));
    calendarConnection
      .querySelectorAll<HTMLFormElement>("[data-resource-form]")
      .forEach((form) => {
        form.addEventListener("submit", async (event) => {
          event.preventDefault();
          if (!supabase || !activeTenantId) return;
          const resourceId = form.dataset.resourceId;
          const formData = new FormData(form);
          const name = String(formData.get("name") || "").trim();
          if (!resourceId || !name) {
            setCalendarMessage("Въведи име на ресурса, например д-р Иванова.");
            return;
          }
          const { error } = await supabase
            .from("calendar_resources")
            .update({ name })
            .eq("id", resourceId)
            .eq("tenant_id", activeTenantId);
          if (error) {
            setCalendarMessage(error.message);
            return;
          }
          setCalendarMessage("Името на ресурса е запазено.");
          await loadCalendarSetup(activeTenantId);
        });
      });
  };

  const loadCalendarSetup = async (tenantId: string) => {
    if (!supabase || !calendarStatus) return;

    const { data: connections, error: connectionError } = await supabase
      .from("calendar_connections")
      .select("id, provider, mode, connected_email, status, selected_calendar_id, selected_calendar_name, metadata, updated_at")
      .eq("tenant_id", tenantId)
      .eq("provider", "google_calendar")
      .eq("status", "connected")
      .order("updated_at", { ascending: false });

    if (connectionError) {
      calendarStatus.textContent = `Не успяхме да заредим calendar връзката: ${connectionError.message}`;
      return;
    }

    const { data: resources } = connections?.length
      ? await supabase
          .from("calendar_resources")
          .select("id, calendar_connection_id, name, provider_calendar_id, provider_calendar_name, provider_account_email, active")
          .eq("tenant_id", tenantId)
          .eq("active", true)
          .order("created_at", { ascending: true })
      : { data: [] };

    renderCalendarConnection(connections || [], resources || []);
  };

  const initApp = async () => {
    if (!supabase || !isSupabaseConfigured) {
      setStatus("Supabase още не е конфигуриран.");
      return;
    }

    const { data } = await supabase.auth.getSession();

    if (!data.session) {
      window.location.assign("/login");
      return;
    }

    const { data: memberships, error } = await supabase
      .from("tenant_members")
      .select("tenant_id, role")
      .limit(1);

    if (error) {
      setStatus(`Не успяхме да заредим бизнес профила: ${error.message}`);
      return;
    }

    const membership = memberships?.[0];

    if (!membership) {
      setStatus("Профилът е активен. Попълнете данните за бизнеса, за да създадем tenant.");
      onboardingForm?.removeAttribute("hidden");
    } else {
      activeTenantId = membership.tenant_id;
      const { data: subscriptions } = await supabase
        .from("subscriptions")
        .select("plan_key, status")
        .eq("tenant_id", membership.tenant_id)
        .limit(1);

      const subscription = subscriptions?.[0];
      if (subscription && planStatus) {
        planStatus.textContent = `План: ${subscription.plan_key} · ${getStatusLabel(subscription.status)}`;
        if (subscription.status === "active") {
          planButtons.forEach((button) => {
            button.disabled = true;
          });
        }
      }

      const { data: jobs } = await supabase
        .from("provisioning_jobs")
        .select("status, step, updated_at")
        .eq("tenant_id", membership.tenant_id)
        .order("created_at", { ascending: false })
        .limit(1);

      const latestJob = jobs?.[0];
      if (latestJob && provisioningStatus) {
        provisioningStatus.textContent = `${getStatusLabel(latestJob.status)} · обновено ${formatDateTime(latestJob.updated_at)}`;
      }

      await Promise.all([
        loadBusinessProfile(membership.tenant_id),
        loadPhoneNumbers(membership.tenant_id),
        loadCalls(membership.tenant_id),
        loadLeads(membership.tenant_id),
        loadCalendarSetup(membership.tenant_id),
      ]);

      setStatus("Профилът е активен.");
      content?.removeAttribute("hidden");
    }

    logout?.removeAttribute("hidden");
  };

  initApp();

  onboardingForm?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!supabase || !onboardingMessage) return;

    const formData = new FormData(onboardingForm);
    onboardingMessage.textContent = "Създаваме бизнес профила...";

    const { error } = await supabase.rpc("create_tenant_onboarding", {
      business_name: String(formData.get("business_name") || ""),
      niche: String(formData.get("niche") || ""),
      city: String(formData.get("city") || ""),
      main_phone: String(formData.get("main_phone") || ""),
      contact_email: String(formData.get("contact_email") || ""),
      wants_booking: formData.get("wants_booking") === "on",
    });

    if (error) {
      onboardingMessage.textContent = error.message;
      return;
    }

    onboardingMessage.textContent = "Бизнес профилът е създаден.";
    window.location.reload();
  });

  planButtons.forEach((button) => {
    button.addEventListener("click", async () => {
      if (!supabase || !planStatus) return;

      const planKey = button.dataset.planKey;
      if (!planKey) return;

      planStatus.textContent = "Записваме избрания план...";
      const { error } = await supabase.rpc("select_subscription_plan", {
        plan_key: planKey,
      });

      if (error) {
        planStatus.textContent = error.message;
        return;
      }

      planStatus.textContent = `План: ${planKey} · Очаква плащане`;
    });
  });

  businessEditToggle?.addEventListener("click", () => {
    const isEditing = businessEditForm?.hasAttribute("hidden") ?? false;
    setBusinessEditing(isEditing);
    if (businessMessage) businessMessage.textContent = "";
  });

  businessEditCancel?.addEventListener("click", () => {
    setBusinessEditing(false);
    if (businessMessage) businessMessage.textContent = "";
  });

  businessEditForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!supabase || !activeTenantId || !businessMessage) return;

    const formData = new FormData(businessEditForm);
    const businessName = String(formData.get("business_name") || "").trim();

    if (!businessName) {
      businessMessage.textContent = "Името на бизнеса е задължително.";
      return;
    }

    businessMessage.textContent = "Запазваме промените...";

    const values = {
      business_name: businessName,
      niche: String(formData.get("niche") || "").trim() || null,
      city: String(formData.get("city") || "").trim() || null,
      main_phone: String(formData.get("main_phone") || "").trim() || null,
      contact_email: String(formData.get("contact_email") || "").trim() || null,
    };

    const { error } = await supabase
      .from("business_profiles")
      .update(values)
      .eq("tenant_id", activeTenantId);

    if (error) {
      businessMessage.textContent = error.message;
      return;
    }

    await supabase
      .from("tenants")
      .update({ name: businessName })
      .eq("id", activeTenantId);

    businessMessage.textContent = "Бизнес профилът е обновен.";
    await loadBusinessProfile(activeTenantId);
    setBusinessEditing(false);
  });

  calendarProviderButtons.forEach((button) => {
    button.addEventListener("click", async () => {
      if (!supabase || !activeTenantId) return;

      const provider = button.dataset.calendarProvider;
      if (!provider) return;

      setCalendarMessage("");

      if (provider === "google_calendar") {
        await startGoogleCalendarAuth("solo_google");
        return;
      }
    });
  });

  logout?.addEventListener("click", async () => {
    if (!supabase) return;
    await supabase.auth.signOut();
    window.location.assign("/login");
  });
</script>

