---
import { site } from "../data/site";

interface Props {
  title?: string;
  text?: string;
}

const {
  title = "Чуйте как ще звучи вашият рецепционист.",
  text = "Демо номерът ще бъде добавен след първите тестови разговори. Сайтът вече е готов да го покаже като основен продавач.",
} = Astro.props;
---

<section class="section-tight">
  <div class="container">
    <div class="cta-band">
      <div>
        <h2 style="font-size: clamp(1.5rem, 2.4vw, 2.35rem); margin-bottom: 8px;">{title}</h2>
        <p style="margin-bottom: 0;">{text}</p>
      </div>
      {
        site.demoPhone ? (
          <a class="btn btn-primary" href={`tel:${site.demoPhone}`}>Обадете се сега</a>
        ) : (
          <span class="btn btn-muted">{site.demoPhoneLabel}</span>
        )
      }
    </div>
  </div>
</section>

