---
import { site } from "../data/site";
---

<header class="header">
  <div class="container nav">
    <a class="brand" href="/" aria-label="Vdiga начало">
      <span class="brand-mark">V</span>
      <span>Vdiga</span>
    </a>
    <nav class="nav-links" aria-label="Основна навигация">
      {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <div class="nav-actions">
      <a class="btn btn-secondary btn-small" href="/login">Вход</a>
      <a class="btn btn-primary btn-small" href="/signup">Регистрация</a>
      <a class="btn btn-secondary btn-small nav-demo" href="/demo">Демо</a>
    </div>
  </div>
</header>
